# ══════════════════════════════════════════════════════════════════
#  SIMULADOR EXHCOBA — Variables de entorno de producción
#  Copiar este archivo a  docker/.env  en el VPS y rellenar valores
#  NUNCA subir docker/.env a git (ya está en .gitignore)
# ══════════════════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CAMBIAR_contrasena_segura
POSTGRES_DB=simulador_examen

# ── JWT ───────────────────────────────────────────────────────────
# Generar con: openssl rand -hex 32
JWT_SECRET=CAMBIAR_secreto_jwt_generado_con_openssl

# ── CORS ─────────────────────────────────────────────────────────
# Sin dominio (solo IP):
CORS_ORIGIN=http://51.79.69.178
# Con dominio: CORS_ORIGIN=https://tudominio.com

# ── Frontend ──────────────────────────────────────────────────────
# Con Nginx en el mismo servidor → dejar VACÍO (usa /api/ relativo)
NEXT_PUBLIC_API_URL=

# ── Puerto HTTP Nginx ─────────────────────────────────────────────
HTTP_PORT=80
