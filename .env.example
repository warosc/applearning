# Variables para docker-compose.prod.yml
# Copiar a .env y ajustar valores

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cambiar_esta_contrasena_en_produccion
POSTGRES_DB=simulador_examen

# Backend
# Generar con: openssl rand -hex 32
JWT_SECRET=cambiar_este_secreto_en_produccion

CORS_ORIGIN=https://examen.tudominio.com

# Frontend — URL pública de la API.
# Con Nginx en el mismo dominio (recomendado), dejar vacío para usar rutas relativas /api/...
# Con dominio separado para la API: NEXT_PUBLIC_API_URL=https://api.tudominio.com
NEXT_PUBLIC_API_URL=

# Puerto HTTP expuesto por Nginx (default: 80)
HTTP_PORT=80

# Redis (opcional — defaults internos si no se define)
# REDIS_URL=redis://redis:6379
